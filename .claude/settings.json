{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(yarn dev)",
      "Bash(yarn dev *)",
      "Bash(yarn build)",
      "Bash(yarn lint)",
      "Bash(yarn lint *)",
      "Bash(yarn install)",
      "Bash(yarn install *)",
      "Bash(yarn run *)",
      "Bash(yarn why *)",
      "Bash(yarn info *)",
      "Bash(yarn outdated)",
      "Bash(yarn --version)",
      "Bash(corepack --version)",
      "Bash(corepack enable)",
      "Bash(node --version)",
      "Bash(npx tsc *)",
      "Bash(yarn tsc *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch)",
      "Bash(git branch *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git fetch *)",
      "Bash(git pull)",
      "Bash(git pull --ff-only)",
      "Bash(git rev-parse *)",
      "Bash(git remote -v)",
      "Bash(git config --get *)",
      "Bash(gh pr view *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh repo view *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(find . *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(wc *)",
      "Bash(cat package.json)",
      "Bash(cat tsconfig.json)",
      "Bash(cat next.config.ts)",
      "Bash(cat tailwind.config.ts)",
      "Bash(jq *)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:framer.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:docs.claude.com)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git push * main)",
      "Bash(git push * origin main)",
      "Bash(git push * master)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(git commit --no-verify *)",
      "Bash(yarn publish *)",
      "Bash(npm publish *)",
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./.env.production)",
      "Read(./.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Read(~/.config/gcloud/**)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)",
      "Bash(yarn add *)",
      "Bash(yarn remove *)"
    ]
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "180000",
    "BASH_MAX_TIMEOUT_MS": "600000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prevent-main-commit.sh",
            "timeout": 10,
            "statusMessage": "Checking branch policy..."
          },
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/prevent-main-commit.sh",
            "timeout": 10,
            "statusMessage": "Checking branch policy..."
          }
        ]
      }
    ]
  }
}
